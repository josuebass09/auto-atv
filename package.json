{
  "name": "factura-cli",
  "version": "1.0.0",
  "description": "CLI para emitir facturas electrónicas CR v4.4 directo al API de Hacienda",
  "type": "module",
  "scripts": {
    "factura": "node --import tsx src/index.ts",
    "cron": "node --import tsx src/cron.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@peculiar/webcrypto": "^1.5.0",
    "@xmldom/xmldom": "^0.8.13",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "node-forge": "^1.3.1",
    "ora": "^9.4.1",
    "xadesjs": "^2.3.7",
    "xmlbuilder2": "^3.1.1",
    "xmldsigjs": "^2.5.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.0",
    "@types/node-forge": "^1.3.11",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
