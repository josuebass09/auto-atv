# Credenciales Hacienda (nunca commitear .env real)
#
# Formato de usuario según tipo de identificación:
#   Persona física:   cpf-01-0000-0000@stag.comprobanteselectronicos.go.cr  (sandbox)
#                     cpf-01-0000-0000@comprobanteselectronicos.go.cr         (producción)
#   Persona jurídica: cpj-3-101-000000@stag.comprobanteselectronicos.go.cr
#   DIMEX:            cpdimex-000000000000@stag.comprobanteselectronicos.go.cr
#
# Nota: el usuario de PRODUCCIÓN NO lleva "@stag." — solo @comprobanteselectronicos.go.cr

# Sandbox
HACIENDA_USERNAME_SANDBOX=cpf-01-0000-0000@stag.comprobanteselectronicos.go.cr
HACIENDA_PASSWORD_SANDBOX=tu_clave_tribu_stag

# Producción (usuario SIN @stag.)
HACIENDA_USERNAME_PRODUCTION=cpf-01-0000-0000@comprobanteselectronicos.go.cr
HACIENDA_PASSWORD_PRODUCTION=tu_clave_tribu_prod

# Contraseña del certificado .p12 (mismo cert para ambos ambientes)
CERT_PASSWORD_SANDBOX=contrasena_del_p12

# Ambiente por defecto: production | sandbox
API_ENV=sandbox
